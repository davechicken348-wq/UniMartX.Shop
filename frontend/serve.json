{
  "cleanUrls": false,
  "trailingSlash": false,
  "headers": [
    {
      "source": "**/*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/404", "destination": "/pages/public/404.html", "type": 301 }
  ]
}
